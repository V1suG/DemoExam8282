<Page x:Class="WPFGUSEVDEMOEX.PurchasesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFGUSEVDEMOEX"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PurchasesPage" IsVisibleChanged="Page_IsVisibleChanged">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="377*"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
        </Grid.RowDefinitions>
        <DataGrid x:Name="DGridPurchases" AutoGenerateColumns="False" IsReadOnly="True" Background="#BBd9B2">
            <DataGrid.Columns>
                <DataGridTextColumn Width="*" Header="Продукт" Binding="{Binding Products_import_.product_name}" ></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Партнер" Binding="{Binding Partners_import_.partner_name}" ></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Количество товара" Binding="{Binding quantity_import}" ></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Дата" Binding="{Binding Date_import}" ></DataGridTextColumn>
                <DataGridTemplateColumn Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Редактировать" Name="BtnEdit_Click"></Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Добавить" Grid.Row="2" HorizontalAlignment="Left" Name="BtnAdd" Click="BtnAdd_Click"></Button>
        <Button Content="Удалить" Grid.Row="2" HorizontalAlignment="Right" Name="Btndelete" Click="BtnDelete_Click"></Button>
    </Grid>
</Page>
