<Page x:Class="WPFGUSEVDEMOEX.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFGUSEVDEMOEX"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditPage">

    <Grid Background="#F4E8D3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Text="Продукт" Grid.Row="0"></TextBlock>
        <TextBlock Text="Партнёр" Grid.Row="1"></TextBlock>
        <TextBlock Text="Количество товара" Grid.Row="2"></TextBlock>
        <TextBlock Text="Дата" Grid.Row="3"></TextBlock>
        <ComboBox SelectedItem="{Binding Products_import_}" Grid.Column="1" Grid.Row="0" x:Name="ComboProducts" DisplayMemberPath="product_name"></ComboBox>
        <ComboBox SelectedItem="{Binding Partners_import_}" Grid.Column="1" Grid.Row="1" x:Name="ComboPartners" DisplayMemberPath="partner_name"></ComboBox>
        <TextBox Text="{Binding quantity_import}" Grid.Column="1" Grid.Row="2"></TextBox>
        <DatePicker SelectedDate="{Binding Date_import}" Grid.Column="1" Grid.Row="3" HorizontalAlignment="Stretch" VerticalAlignment="Center"></DatePicker>
        <Button Content="Сохранить" Grid.Row="4" Name="BtnSave" Click="BtnSave_Click" Background="#FF2D6033" Margin="113,26,313,26" Grid.Column="1"/>
    </Grid>
</Page>
